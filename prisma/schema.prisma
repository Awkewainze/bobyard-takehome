// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
    runtime  = "bun"
}

datasource db {
    provider = "postgresql"
}

model Comment {
    id     Int      @id @default(autoincrement())
    author String
    text   String
    date   DateTime @default(now())
    likes  Int
    image  String

    @@map("comments")
}
