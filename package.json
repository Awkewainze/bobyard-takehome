{
	"name": "bobyard-takehome",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"barrel": "barrelsby --delete -l all -d ./src",
		"db:generate-client": "bunx --bun prisma generate",
		"db:create-migration": "bunx --bun prisma migrate dev",
		"db:migrations": "bunx --bun prisma migrate deploy",
		"db:seed": "bun run prisma/seed.ts",
		"db:fresh": "bun run db:generate-client && bun run db:migrations && bun run db:seed",
		"dev": "bun --hot src/server.ts",
		"dev:fresh-db": "bun run db:fresh && bun run dev",
		"build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
		"start": "NODE_ENV=production bun src/server.ts",
		"start:fresh-db": "bun run db:fresh && bun run start"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"@tailwindcss/postcss": "^4.2.1",
		"barrelsby": "^2.8.1",
		"bun-plugin-tailwind": "^0.1.2",
		"postcss": "^8.5.8",
		"react": "^19",
		"react-dom": "^19",
		"react-infinite-scroll-component": "^6.1.1",
		"react-router": "^7.9.5",
		"tailwindcss": "^4.2.1",
		"usehooks-ts": "^3.1.1",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"prisma": "^7.5.0"
	}
}